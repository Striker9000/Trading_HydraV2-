# Trading Hydra Environment Configuration
# Copy this to .env and fill in your values
# chmod 600 .env to protect credentials

# ============================================================
# Broker Mode (IMPORTANT)
# ============================================================
# Default to paper trading for safety
ALPACA_PAPER=true

# ============================================================
# Alpaca API Credentials (REQUIRED)
# ============================================================
# Get these from:
#   Paper trading: https://paper.alpaca.markets (API Keys section)
#   Live trading:  https://alpaca.markets (API Keys section)
#
# IMPORTANT: Paper and live keys are NOT interchangeable!
# Make sure ALPACA_PAPER matches your key type.
ALPACA_KEY=
ALPACA_SECRET=

# API base URL (auto-set based on ALPACA_PAPER, but can override)
# Paper: https://paper-api.alpaca.markets
# Live:  https://api.alpaca.markets
# ALPACA_BASE_URL=

# ============================================================
# Database (Optional)
# ============================================================
# SQLite path for local state
SQLITE_PATH=/var/lib/trading-hydra/trading_state.db

# Hub MySQL (for multi-bot deployment, leave blank for single bot)
# HUB_DB_HOST=
# HUB_DB_PORT=3306
# HUB_DB_NAME=hydra
# HUB_DB_USER=hydra
# HUB_DB_PASS=

# ============================================================
# Safety Limits
# ============================================================
# Maximum daily loss in dollars before auto-halt
MAX_DAILY_LOSS=50

# Require explicit confirmation for live trading
# Set to "I_UNDERSTAND_LIVE_TRADING" to enable live mode
LIVE_TRADING_CONFIRMATION=

# ============================================================
# Dashboard (Web UI)
# ============================================================
# Dashboard is OFF by default for security
# Set to true to enable web dashboard on port 5000
ENABLE_DASHBOARD=false

# ============================================================
# Logging
# ============================================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log directory
HYDRA_LOG_DIR=/var/log/trading-hydra

# ============================================================
# System
# ============================================================
# Timezone (PST default)
TZ=America/Los_Angeles

# Loop interval in seconds
HYDRA_LOOP_INTERVAL=5
