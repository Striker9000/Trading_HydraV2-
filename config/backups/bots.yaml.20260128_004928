    openai_sentiment:
      enabled: true
      model: gpt-4o-mini  # Fast and cheap
      timeout_seconds: 5
    
    # Exit triggers (Phase 1)
    exits:
      enabled: true  # Enable news-based exits
      negative_threshold: -0.70  # Exit on sentiment <= this (if profitable)
      severe_threshold: -0.85  # Exit even if losing position
      min_confidence: 0.60  # Minimum confidence to act
      profit_exit_requires_profit: true  # Normal exits only if position is green
      loss_exit_on_severe: true  # Severe news exits even if red
    
    # Entry filters (Phase 2)
    entry_filter:
      enabled: true  # Enable news-based entry filtering
      bullish_min: 0.20  # Min sentiment for call entries
      bearish_max: -0.20  # Max sentiment for put entries
      neutral_band: 0.15  # Treat abs(sentiment) < this as neutral
      mixed_handling: skip  # skip | reduce_size | allow
  
  # Phase 3: Smart Money (Congress + 13F)
  smart_money:
    enabled: true  # ENABLED by default - core institutional intelligence
    refresh_seconds: 3600  # Refresh hourly (data changes slowly)
    congress:
      enabled: false
      min_conviction: 0.50
      min_trade_value: 15000  # Minimum trade value to consider
    institutional:
      enabled: false
      min_convergence: 0.30  # Multiple funds buying
    boost_factor: 1.2  # Universe scoring boost for smart money signals
  
  # Phase 4: Macro Intelligence (Fed + White House)
  macro:
