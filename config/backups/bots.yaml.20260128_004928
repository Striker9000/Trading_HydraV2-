    hawkish_caution_threshold: 0.40  # Become CAUTION at this level
    hawkish_stress_threshold: 0.70  # Become STRESS at this level
    stress_size_multiplier: 0.5  # Reduce position sizes 50% in STRESS
    caution_size_multiplier: 0.75  # Reduce 25% in CAUTION

# =============================================================================
# LIQUIDITY FILTER - Options bid-ask spread and volume requirements
# =============================================================================
# Prevents trading options with insufficient liquidity that would result in
# slippage losses and difficulty exiting positions.
liquidity_filter:
  enabled: true
  max_spread_pct: 10.0      # Max bid-ask spread as % of mid price (10%)
  min_dollar_volume: 50000  # Minimum daily dollar volume ($50k)
  min_open_interest: 100    # Minimum open interest (contracts)
  
  # Real-time check before order placement
  pre_order_check: true     # Fetch fresh quote before submitting order
  
  # Early session relaxation (first 20 min of market)
  early_session_max_spread_pct: 15.0  # Wider spread allowed at open
  early_session_min_oi: 50            # Lower OI threshold at open

# =============================================================================
# EDGE DECAY MONITORING - Track strategy performance degradation
# =============================================================================
# Monitors rolling Sharpe ratios to detect when strategies are losing edge.
edge_decay:
  enabled: true
  # Rolling window sizes (days)
  short_window: 7
  medium_window: 30
  long_window: 90
  
  # Decay ratio thresholds (30d Sharpe / 90d Sharpe)
  healthy_ratio: 0.8       # Above this = healthy
  warning_ratio: 0.5       # Below this = warning
  degraded_ratio: 0.3      # Below this = reduce allocation 50%
  
  # Minimum Sharpe for healthy status
  min_sharpe_healthy: 0.5
  min_sharpe_viable: 0.0

# =============================================================================
# CROSS-BOT CORRELATION MONITOR - Aggregate exposure limits
# =============================================================================
# Prevents all bots from going the same direction, which would cause
# correlated drawdowns during market crashes.
cross_bot_monitor:
  enabled: true
  # Exposure limits (as % of equity)
  max_net_delta_pct: 40.0   # Max net directional exposure
  near_limit_pct: 30.0      # Warning threshold
  max_sector_pct: 30.0      # Max exposure to single sector
  
  # Cross-bot loss detection
  loss_window_minutes: 60   # Window for detecting correlated losses
  loss_trigger_count: 3     # Number of bots losing to trigger pause

# =============================================================================
# SLIPPAGE TRACKING - Monitor execution quality
# =============================================================================
# Records actual vs expected fill prices to measure execution quality
# and build a slippage model for backtesting.
slippage_tracking:
  enabled: true
  # Thresholds (basis points)
  acceptable_bps: 10        # Normal slippage (0.10%)
  warning_bps: 25           # Warning level (0.25%)
  severe_bps: 50            # Severe slippage (0.50%)
  
  # VIX-adjusted sizing
  vix_slippage_multiplier: true  # Increase expected slippage in high VIX

# =============================================================================
# ML DRIFT DETECTION - Monitor model accuracy over time
# =============================================================================
# Detects when ML models need retraining due to distribution shift.
ml_drift:
  enabled: true
  # Detection thresholds
  ks_threshold: 0.3             # Kolmogorov-Smirnov statistic for feature drift
  calibration_threshold: 0.15   # Max allowed calibration error
  accuracy_drop_threshold: 0.10 # Accuracy drop to trigger warning (10%)
  
  # Retraining schedule
  auto_retrain: false           # Set true to enable scheduled retraining
  retrain_interval_days: 90     # Retrain every 90 days if enabled