optionsbot:
  enabled: true
  bot_id: opt_core
  # Strategy System Integration (PDF rules-based strategies)
  # When enabled, uses StrategyRunner from config/strategies/*.yaml
  # When disabled, uses existing behavior (no change)
  use_strategy_system: true
  # Using cheaper underlyings that require less buying power
  tickers: [AAPL, AMD, MSFT, NVDA, TSLA, PLTR, BLK]
  session:
    trade_start: "06:40"    # PST: 9:40 AM EST
    trade_end: "12:30"      # PST: 3:30 PM EST (30min before close)
    manage_until: "13:00"   # PST: 4:00 PM EST
  # Mode-based DTE rules to enable short-term trades (previously excluded)
  default_mode: swing       # Default mode: "swing" or "short_term"
  # IV Percentile Entry Gate - Only trade when IV is in favorable range
  # For BUYING options (long calls/puts): Want LOW IV (buy cheap)
  # For SELLING options (shorts/spreads): Want HIGH IV (sell expensive)
  iv_gate:
    enabled: true
    # Long options: Only buy when IV is below this percentile (buy cheap)
    buy_max_iv_percentile: 60    # Don't buy when IV > 60th percentile
    buy_min_iv_percentile: 10    # Don't buy when IV < 10th percentile (too quiet)
    # Credit/sell strategies: Only sell when IV is above this percentile
    sell_min_iv_percentile: 50   # Don't sell unless IV > 50th percentile
    # Straddles need elevated IV for premium capture
    straddle_min_iv_percentile: 40
  risk:
    max_trades_per_day: 15       # INCREASED: Allow more trades per day
    max_concurrent_positions: 8  # INCREASED: Allow more concurrent positions
    max_position_size_usd: 500   # INCREASED: $500 per position for $43,500 account
    profit_target_usd: 75        # INCREASED: Larger profit target
    trailing_stop:
      enabled: true
      mode: percent
      value: 2.0
      activation_profit_pct: 50  # Activate after 50% profit (options)
      update_only_if_improves: true
      epsilon_pct: 0.05
      exit_order:
        type: market
  strategies:
    # BUY-SIDE ONLY - No selling options (avoids margin/buying power issues)
    long_call:
      enabled: true
      max_cost: 3.00         # Max $3 per contract ($300 for 1 contract)
      min_delta: 0.30        # Not too far OTM
      max_delta: 0.60        # Not too deep ITM
      profit_target: 0.30    # 30% gain target
    long_put:
      enabled: true
      max_cost: 3.00
      min_delta: 0.30
      max_delta: 0.60
      profit_target: 0.30
    straddle:
      enabled: true
      max_cost: 5.00         # Max $5 per straddle
      profit_target: 0.25
    # DISABLED - Credit spreads require margin/cash securing
    bull_put_spread:
      enabled: true
      min_credit: 0.50
      max_credit: 3.00
      profit_target: 0.50
      max_dte: 45
    bear_call_spread:
      enabled: true
      min_credit: 0.50
      max_credit: 3.00
      profit_target: 0.50
      max_dte: 45
    iron_condor:
      enabled: true
      min_credit: 1.00
      max_credit: 4.00
      profit_target: 0.25
      max_dte: 60
  exits:
    take_profit_pct: 30      # Take 30% profit on long options
    stop_loss_pct: 50        # 50% stop loss (tighter for long options)
    time_stop_minutes: 180   # 3 hours max hold for long options
    flatten_before_close_minutes: 30
  chain_rules:
