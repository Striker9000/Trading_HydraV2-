# =============================================================================
# PRE-STAGED ENTRIES - Predetermined entries ready before market open
# =============================================================================
# Runs at 6:00 AM PST to identify setups and calculate entry levels BEFORE
# the move happens. Entries are "staged" and ready to execute immediately.
#
# Setup Types:
# - GAP_DOWN_BREAKDOWN: Puts when gap down continues lower
# - GAP_UP_BREAKOUT: Calls when gap up continues higher
# - GAP_FADE_REVERSAL: Counter-trend when gaps fail
# - REVERSAL_BOUNCE: Mean reversion when oversold/overbought reverses
prestaged_entries:
  enabled: true
  scan_start_time: "06:00"        # Start scanning at 6:00 AM PST
  entry_window_start: "06:30"     # Entries can trigger starting at 6:30 AM
  entry_window_end: "07:30"       # Entries expire if not triggered by 7:30 AM
  
  # Gap detection thresholds
  min_gap_pct: 0.5                # Minimum gap to consider (0.5%)
  large_gap_pct: 1.5              # Large gap that may fade (1.5%)
  
  # Entry trigger buffers (how far past open price to trigger)
  breakdown_buffer_pct: 0.15      # Trigger puts 0.15% below gap low
  breakout_buffer_pct: 0.15       # Trigger calls 0.15% above gap high
  
  # Reversal detection
  reversal_deviation_pct: 2.0     # Deviation from 4-day avg for reversal
  
  # Default targets/stops for staged entries
  default_target_pct: 1.5         # Target 1.5% move
  default_stop_pct: 0.75          # Stop at 0.75% loss
  
  # Limits
  max_staged_per_symbol: 2        # Max 2 staged entries per symbol
  max_total_staged: 10            # Max 10 total staged entries
  
  # Option parameters for staged entries
  preferred_dte_min: 3            # Minimum 3 DTE
  preferred_dte_max: 14           # Maximum 14 DTE
  max_option_premium: 3.00        # Max $3.00 per contract
  
  # Watchlist for premarket scanning
  watchlist:
    - SPY
    - QQQ
    - IWM
    - XLF
    - XLE
    - XLK
    - AAPL
    - MSFT
    - NVDA
    - TSLA
    - AMD
    - META
    - AMZN
    - GOOGL
    - SMCI
    - AVGO
    - COIN

# =============================================================================
# GREEK RISK LIMITS - Portfolio-level delta/gamma caps
# =============================================================================
# Institutional-grade controls for options exposure. Prevents over-concentration
# of directional (delta) or acceleration (gamma) risk.
#
# Delta: Expressed as % of equity. 20% means max directional exposure of $8,700
#        on a $43,500 account (equivalent to ~17 SPY shares at $500).
# Gamma: Rate of delta change per $1 underlying move. High gamma = acceleration risk.
greek_limits:
  enabled: true
  max_delta_pct_of_equity: 20.0    # Max 20% of equity in directional exposure
  max_gamma_per_dollar: 5.0        # Max gamma per $1 underlying move
  max_vega_per_iv_point: 500.0     # Max vega per 1% IV change
  max_theta_daily_usd: 100.0       # Max daily theta decay (absolute value)
  delta_warning_pct: 80.0          # Warn at 80% of delta limit
  gamma_warning_pct: 80.0          # Warn at 80% of gamma limit

# =============================================================================
# P&L ATTRIBUTION - Track how much P&L comes from each Greek
# =============================================================================
# Decomposes option P&L into delta, gamma, theta, vega, and residual components.
# Helps understand if profits come from directional bets, time decay, or volatility.
pnl_attribution:
  enabled: true

exitbot:
  enabled: true
  cooloff_minutes: 390
  kill_conditions:
    api_failure_halt: true
    data_stale_halt: true
    max_daily_loss_halt: true
    anomaly_halt: true
  # Default trailing stop for manual trades (user-created positions)
  # Bots use their own trailing stop config from their respective sections
  default_trailing_stop:
    enabled: true
    mode: percent          # "percent" or "price"
    value: 1.0             # 1.0% trailing stop for manual trades
    activation_profit_pct: 50  # Activate after 50% profit (manual trades)
    update_only_if_improves: true
    epsilon_pct: 0.02      # Buffer to prevent noise triggers
    exit_order_type: market
    # REVERSAL-SENSE TRAILING STOP (optional enhancement)
    # Detects momentum/volume reversals and dynamically tightens stops
    # Signals: momentum deceleration, volume spikes on adverse moves, reversal candles
    reversal_sense:
      enabled: true
      # Momentum reversal detection
      momentum_lookback: 5            # Bars to calculate momentum
      momentum_reversal_threshold: 0.5  # Min momentum change % to trigger
      # Volume spike detection  
      volume_spike_mult: 2.0          # Volume > 2x avg = spike
      volume_lookback: 20             # Bars for avg volume calc
      # Price action reversal
      reversal_candle_body_pct: 70.0  # Strong reversal candle (body > 70% of range)
      # Tightening behavior
      reversal_tighten_ratio: 0.4     # Tighten by 40% on reversal signal
      strong_reversal_tighten_ratio: 0.6  # Tighten by 60% on strong reversal
      cooldown_minutes: 15            # Don't re-tighten within 15 min
      max_tightenings: 3              # Max tightenings before hitting stop
  
  # ==========================================================================
  # HARD STOP-LOSS ENFORCEMENT
  # ==========================================================================
  # Exits FULL position if it drops X% from entry, regardless of trailing stop.
  # This is the absolute safety net - protects capital when trailing stops 
  # haven't armed yet (position never reached profit threshold).
  # 
  # Dynamic adjustments:
  # - VIX regime: tightens by 25% during high volatility regimes
  # - ATR scaling: (future) scale stops based on asset volatility
  # - ML confidence: (future) widen for high-confidence trades
  hard_stop:
    enabled: true
    # Default stop percentages by asset class (can be overridden per-bot):
    # - crypto: uses cryptobot.exits.stop_loss_pct (currently 0.4%)
    # - options: uses optionsbot.exits.stop_loss_pct (currently 50%)  
    # - equities: uses momentum_bot.exits.stop_loss_pct (currently 2%)
    # - manual trades: uses default_stop_loss_pct below
    default_stop_loss_pct: 5.0  # 5% default for manual/unassigned positions
    vix_regime_tighten: true    # Tighten by 25% in high VIX regimes
    atr_scaling: false          # Future: scale by ATR
    ml_confidence_adjust: false # Future: adjust based on ML confidence
  
  # ==========================================================================
  # TIERED TAKE-PROFIT TARGETS (TP1, TP2, TP3)
  # ==========================================================================
  # Executes PARTIAL position exits at profit milestones:
  # - TP1: Exit 33% of position, move stop to breakeven
  # - TP2: Exit 50% of remaining, move stop to TP1 level  
  # - TP3: Exit 100% of remaining (full exit)
  #
  # Benefits:
  # - Locks in profits progressively
  # - Reduces risk as profit grows
  # - Lets winners run with house money
  #
  # Note: Target percentages are scaled per asset class from bot configs.
  take_profit:
    enabled: true
    # Exit percentages at each tier
    tp1_exit_pct: 0.33    # Exit 33% at first target
    tp2_exit_pct: 0.50    # Exit 50% of remaining at second target
    tp3_exit_pct: 1.00    # Exit all remaining at third target
    # Stop adjustment after hitting targets
    move_stop_after_tp1: breakeven  # "breakeven" or "none"
    move_stop_after_tp2: tp1        # "tp1" or "none" (move stop to TP1 level)
    # Dynamic scaling (future)
    atr_scaling: false    # Scale TP levels by ATR
    atr_multiplier: 1.5   # ATR multiplier for TP distances
    
    # ========================================================================
    # PARABOLIC RUNNER MODE
    # ========================================================================
    # After TP2 hits, disable TP3 and let trailing stop ride extended moves.
    # Instead of forcing full exit at TP3, the trailing stop follows the peak.
    # This captures the tail of parabolic runs instead of exiting too early.
    #
    # How it works:
    # 1. TP1 hits (e.g., +3%) -> Exit 33%, move stop to breakeven
    # 2. TP2 hits (e.g., +6%) -> Exit 50%, move stop to TP1 level
    # 3. RUNNER MODE ACTIVATES -> TP3 disabled, trailing stop rides the move
    # 4. Price peaks at +25% -> Trailing stop follows
    # 5. Price retraces 2% from peak -> Trailing stop triggers exit
    #
    # Result: Captured +23% on remaining position vs +10% with TP3
    parabolic_runner:
      enabled: true                     # Enable runner mode after TP2
      widen_trailing_pct: 50.0          # Widen trailing stop by 50% to give room
      min_profit_to_activate: 0.0       # Minimum profit % above TP2 to activate (0 = immediate)
      # ATR-based adaptive thresholds - auto-adjust based on volatility
      adaptive:
        enabled: true                   # Enable ATR-based adaptive thresholds
        atr_period: 14                  # ATR lookback period
        base_atr_mult_tp1: 0.5          # TP1 = base + (ATR * this multiplier)
        base_atr_mult_tp2: 1.0          # TP2 = base + (ATR * this multiplier)
        base_atr_mult_tp3: 2.0          # TP3 = base + (ATR * this multiplier)
        min_tp1_pct: 1.5                # Floor for TP1 (never lower)
        max_tp1_pct: 4.0                # Ceiling for TP1 (never higher)
        min_tp2_pct: 3.0                # Floor for TP2
        max_tp2_pct: 8.0                # Ceiling for TP2
        min_tp3_pct: 6.0                # Floor for TP3
        max_tp3_pct: 15.0               # Ceiling for TP3

