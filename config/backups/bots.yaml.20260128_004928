    max_spread_pct: 10.0             # Maximum bid/ask spread allowed
    min_price_usd: 0.0001            # Minimum coin price
    max_coins: 10                    # Max coins for initial screening
    prefer_high_volume: true         # Weight volume in ranking
    prefer_high_volatility: true     # Weight volatility for momentum plays
    exclude_stablecoins: true        # Exclude USDT, USDC, etc.
    usd_pairs_only: true             # Only /USD pairs (not BTC/ETH pairs)
    refresh_interval_minutes: 60     # Cache refresh interval
    # Two-stage ML selection: screen top 10, ML-score for profitability, pick best 3
    ml_rerank_enabled: true          # Enable ML-based re-ranking
    ml_rerank_candidates: 10         # Number of candidates to evaluate with ML
    ml_rerank_select: 3              # Final number of coins to trade
  session:
    trade_start: "04:00"           # CHANGED: Skip 00:00-04:00 low-liquidity hours
    trade_end: "23:59"
    manage_until: "23:59"
    # Quiet hours: 00:00-04:00 PST is lowest liquidity (Asia sleep, US sleep, EU pre-open)
    # This prevents trailing stops from triggering on flash wicks during thin markets
    quiet_hours_enabled: true
    quiet_hours_start: "00:00"
    quiet_hours_end: "04:00"
  execution:
    order_type: limit
    tif: gtc
    use_notional: true
    # Dynamic sizing: use equity_pct of account, with min/max bounds
    dynamic_sizing_enabled: true
    equity_pct: 3.5                 # INCREASED: Use 1.5% of account equity per trade ($650 at $43,500)
    min_notional_usd: 15            # Minimum trade size (increased for meaningful positions)
    max_notional_usd: 5000           # Maximum trade size cap (increased)
    default_notional_usd: 100       # Fallback if dynamic sizing fails
  risk:
    max_trades_per_day: 5
    max_concurrent_positions: 5
    min_order_size: 10.0  # Above Alpaca's $10 minimum with buffer
    trailing_stop:
      enabled: true
      mode: percent
      value: 0.6               # TIGHTENED from 1.5% to lock in profits faster at peaks
      activation_profit_pct: 15  # Activate after 15% profit (crypto)
      update_only_if_improves: true
      epsilon_pct: 0.03        # Smaller buffer for quicker updates
      exit_order:
        type: market
  exits:
    stop_loss_pct: 1.2            # WIDENED from 0.4% - avoid whipsaw stops on normal noise
    take_profit_pct: 2.0          # INCREASED from 0.8% - let winners run to overcome slippage
    time_stop_minutes: 240
  # PARABOLIC RUNNER - Crypto-specific thresholds (higher than equities due to volatility)
  # Crypto moves are bigger; need wider thresholds to capture 20-50% runs
  parabolic_runner:
    enabled: true
    # Higher thresholds for crypto volatility
    tp1_pct: 4.0                  # First target at 4% (vs 2% equities)
    tp2_pct: 8.0                  # Second target at 8% (vs 4% equities)
    tp3_pct: 15.0                 # Third target at 15% (vs 8% equities)
    widen_trailing_pct: 70.0      # Widen trailing stop by 70% (vs 50% equities)
    # ATR-based adaptive thresholds - auto-adjust based on volatility
    adaptive:
      enabled: true               # Enable ATR-based adaptive thresholds
      atr_period: 14              # ATR lookback period
      base_atr_mult_tp1: 1.0      # TP1 = base + (ATR * this multiplier)
      base_atr_mult_tp2: 2.0      # TP2 = base + (ATR * this multiplier)
      base_atr_mult_tp3: 3.5      # TP3 = base + (ATR * this multiplier)
      min_tp1_pct: 2.0            # Floor for TP1 (never lower)
      max_tp1_pct: 8.0            # Ceiling for TP1 (never higher)
      min_tp2_pct: 5.0            # Floor for TP2
      max_tp2_pct: 15.0           # Ceiling for TP2
      min_tp3_pct: 10.0           # Floor for TP3
      max_tp3_pct: 30.0           # Ceiling for TP3
  # ANTI-CHURN PROTECTION - Prevents overtrading and whipsaw losses
  # Problem: Bot was entering/exiting 15+ times in 4 hours, losing ~$50-100 each round-trip
  anti_churn:
    enabled: true
    # Minimum hold time before regular stop-loss can trigger (hard stop always works)
    min_hold_minutes: 10           # Wait 10 minutes before allowing soft stop-loss
    # Extended cooldown after stop-out (prevents revenge trading)
    stop_out_cooldown_minutes: 30  # 30 minutes after stop-loss (vs 1 minute normal)
    # Whipsaw detection - pause trading after consecutive losses
    max_consecutive_stopouts: 3    # After 3 stop-outs on same symbol
    whipsaw_pause_minutes: 120     # Pause trading that symbol for 2 hours
  # Turtle Traders Strategy Configuration (24/7 markets)
  # Uses hourly bars with equivalent lookbacks (480 periods = 20 days)
  turtle:
    enabled: true
    system: "system_1"
    entry_lookback: 480            # 20 days * 24 hours (hourly bars)
    exit_lookback: 240             # 10 days * 24 hours (hourly bars)
    atr_period: 480                # 20 days * 24 hours (hourly bars)
    risk_pct_per_unit: 1.0
    stop_loss_atr_mult: 2.0
    pyramid_enabled: true
    pyramid_trigger_atr: 0.5
    max_units: 4
    winner_filter_enabled: true
  signal:
    mode: "turtle"
    params: {}

# =============================================================================
# WHIPSAW TRADER - Profit from Range-Bound Markets
# =============================================================================
# When markets are whipsawing (2+ consecutive stop-outs), switches from momentum
# to mean-reversion strategy. Buys at support, sells at resistance with tight TPs.
# Exits when range breaks (volatility expansion) and returns to momentum mode.

whipsaw_trader:
  enabled: true
  # Detection thresholds
  consecutive_stopouts_threshold: 2    # Stop-outs to trigger whipsaw mode
  stopout_window_minutes: 120          # Window for counting stop-outs
  atr_compression_ratio: 0.6           # ATR < 60% of avg = compression
  # Range calculation
  range_lookback_bars: 20              # Bars to calculate support/resistance
  support_buffer_pct: 0.2              # Buffer above support for entries
  resistance_buffer_pct: 0.2           # Buffer below resistance for entries
  # Mean-reversion trading params
  take_profit_pct: 0.75                # Quick 0.75% take profit
  stop_loss_pct: 0.5                   # Tight 0.5% stop loss
  max_trades_in_range: 5               # Max trades before re-evaluation
  # Exit conditions (return to trending mode)
  volatility_expansion_ratio: 1.5      # ATR > 150% of range ATR = breakout
  range_break_pct: 1.0                 # Price breaks range by 1% = exit mode
  min_whipsaw_duration_minutes: 30     # Stay in whipsaw mode at least 30 min
  max_whipsaw_duration_hours: 8        # Force re-evaluation after 8 hours

# =============================================================================
# BOUNCEBOT - Overnight Crypto Dip-Buying Strategy
# =============================================================================
# Captures overnight crypto drawdowns during 1-5:30am PST when volatility spikes.
# Strategy: Buy the dip on oversold conditions, ride the bounce back up.
# Separate from CryptoBot to avoid interference and maintain independent risk limits.

bouncebot:
  enabled: true
  bot_id: "bounce_core"
  # Top liquid pairs only for overnight (thinner liquidity = stick to majors)
  pairs: ["BTC/USD", "ETH/USD", "SOL/USD"]
  
  # Overnight window (PST) - when crypto sees consistent volatility
  session:
    window_start: "01:00"    # 1:00 AM PST
    window_end: "05:30"      # 5:30 AM PST
  
  # Entry criteria - looking for oversold dips
  entry:
    drawdown_threshold_pct: 1.5   # Minimum drawdown from 4-hour high
    rsi_oversold: 30              # RSI must be below this (oversold)
    require_reversal_candle: true # Wait for green candle after red
    lookback_hours: 4             # Hours to look back for recent high
  
  # Execution settings
  execution:
    order_type: market
    tif: gtc
    use_notional: true
    equity_pct: 1.75              # 1.75% of account per trade
    min_notional_usd: 15          # Minimum trade size
    max_notional_usd: 1000        # Maximum trade size
  
  # Risk controls - tighter for overnight
  risk:
    max_trades_per_session: 2     # Max 2 trades per overnight window
    position_size_multiplier: 0.5 # 50% of normal size for overnight
    trailing_stop:
      enabled: true
      mode: percent
      value: 0.5                  # 0.5% trailing stop (tight for bounces)
      activation_profit_pct: 0.4  # Activate after 0.4% profit
      update_only_if_improves: true
      epsilon_pct: 0.02
      exit_order:
        type: market
  
  # Exit settings - quick profits, tight stops
  exits:
    take_profit_pct: 0.8          # +0.8% quick take-profit
    stop_loss_pct: 0.5            # -0.5% tight stop-loss
    max_hold_minutes: 120         # Max 2 hours hold time

# =============================================================================
# MARKET INTELLIGENCE SYSTEM
# =============================================================================
# All intel modules are DISABLED by default (fail-closed)
# Enable modules individually after testing

intelligence:
  # Global settings
  dry_run: false  # Log actions without executing trades
  
  # Debug mode (ONLY for simulation/testing)
  debug:
    simulation_mode: false
    force_active: false
    ignore_neutral_band: false
    lower_confidence_floor: 0.0
  
