system:
  timezone: America/Los_Angeles
  log_path: ./logs/app.jsonl
  state_db_path: ./state/trading_state.db
market_hours:
  market_open: 06:00
  market_close: '13:00'
  pre_market_start: 01:00
  after_hours_end: '17:00'
  pre_market_intel_start: 06:00
  pre_market_intel_end: 06:30
runner:
  loop_interval_seconds: 15
console:
  mode: full
  inplace: false
safety:
  fail_closed: true
  allow_budget_fallback: false
  global_cooldown_minutes: 15
risk:
  pdt_equity_floor_usd: 25250.0
  global_max_daily_loss_pct: 2.0
  max_orders_per_minute: 12
  dynamic_sizing:
    enabled: false
    equity_pct_per_trade: 2.0
    min_position_usd: 50.0
    max_position_usd: 500.0
    scale_on_loss: true
    loss_scale_factor: 0.5
    scale_on_win: true
    win_scale_factor: 1.25
    max_consecutive_scale_ups: 3
development:
  enable_mock_data: false
  mock_market_hours: false
dev:
  use_mock_data: false
trading:
  global_halt: false
  allow_live: true
health:
  max_price_staleness_seconds: 15
  max_api_failures_in_window: 5
  max_connection_failures_in_window: 3
  api_failure_window_seconds: 60
caching:
  quote_ttl_seconds: 15
  account_ttl_seconds: 60
  market_closed_poll_seconds: 60
ml:
  enabled: false
  min_training_days: 30
  min_probability: 0.5
  fallback_on_unavailable: true
  log_all_scores: true
  options_threshold: 0.5
  crypto_threshold: 0.4
  momentum_threshold: 0.5
  adaptive:
    enabled: true
    low_vix_bonus: 0.05
    high_vix_penalty: 0.05
    earnings_bonus: 0.02
account_analytics:
  enabled: true
  risk_adjustment:
    enabled: true
    min_multiplier: 0.25
    max_multiplier: 1.5
    override: true
  bot_allocation:
    enabled: true
    use_ml_weights: true
  regime_sizing:
    enabled: true
    override_rule_based: true
  drawdown_prediction:
    enabled: false
    halt_threshold: 1.0
    reduce_threshold: 1.0
  anomaly_detection:
    enabled: false
    halt_on_anomaly: false
    sensitivity: 0.1
institutional_sizing:
  enabled: true
  base_risk_pct: 5.0
  max_single_position_pct: 10.0
  kelly_fraction: 0.35
  min_notional: 500.0
  max_notional: 10000.0
correlation_management:
  enabled: true
  max_pairwise_correlation: 0.65
  max_sector_exposure_pct: 25.0
  max_single_asset_pct: 10.0
performance_targets:
  sharpe_ratio: 1.8
  win_rate: 0.58
  profit_factor: 1.8
  max_drawdown_monthly_pct: 8.0
premarket:
  enabled: true
  top_n: 5
  min_score: 0.35
  fail_closed: false
  output_file: logs/premarket_selection.json
  weights:
    gap: 0.4
    vol_surge: 0.25
    iv: 0.2
    catalyst: 0.15
smart_execution:
  enabled: true
  use_limit_orders: true
  twap_threshold_usd: 3000
  slippage_buffer_pct: 0.08
  max_spread_pct: 3.0
dynamic_budget:
  enabled: true
  daily_budget_pct: 5.0
  max_position_pct: 10.0
  min_daily_budget_usd: 1000.0
  max_daily_budget_usd: 15000.0
  dd_threshold_reduce: 0.15
  dd_threshold_halt: 0.1
  dd_min_multiplier: 0.6
  performance_scaling_enabled: true
  perf_max_boost: 1.3
correlation_guard:
  enabled: true
  window_minutes: 15
  trigger_count: 2
  halt_count: 4
  reduce_multiplier: 0.75
  cooldown_minutes: 15
vol_of_vol:
  enabled: true
  roc_spiking_threshold: 10.0
  roc_crisis_threshold: 15.0
  vix_crisis_min: 30.0
news_risk_gate:
  enabled: true
  severe_threshold: -0.9
  negative_threshold: -0.5
  cautious_threshold: -0.4
  min_confidence_exit: 0.6
  min_confidence_entry: 0.5
pnl_monitor:
  enabled: true
  fat_tail_k: 3.0
  min_samples: 20
  halt_fat_tail_count: 3
  halt_cooldown_minutes: 30
adversarial_execution:
  enabled: false
  mode: hostile
  spread_explosion_prob: 0.05
  quote_lag_prob: 0.1
  partial_fill_prob: 0.08
  slippage_prob: 0.15
  cancel_fail_prob: 0.03
risk_integration:
  enabled: true
  dry_run: false
  budget_manager:
    enabled: true
  correlation_guard:
    enabled: true
  vol_of_vol:
    enabled: true
  pnl_monitor:
    enabled: true
  news_gate:
    enabled: true
  macro_intel:
    enabled: true
  smart_money:
    enabled: true
policy_gate:
  enabled: true
  dry_run: false
  slippage_budget_pct: 0.5
  min_ml_confidence: 0.4
  require_ml_signal: false
order_state_machine:
  enabled: true
  max_pending_age_minutes: 30
  max_unknown_age_minutes: 60
  reconcile_interval_seconds: 60
ml_governance:
  enabled: true
  min_sharpe_threshold: 0.3
  degraded_sharpe_threshold: 0.5
  decay_ratio_threshold: 0.5
  consecutive_degraded_days_limit: 3
  require_human_reenable: true
circuit_breakers:
  enabled: true
  alpaca_market_data:
    failure_threshold: 5
    timeout_seconds: 10.0
    recovery_timeout_seconds: 60.0
  alpaca_trading:
    failure_threshold: 3
    timeout_seconds: 15.0
    recovery_timeout_seconds: 30.0
  openai_sentiment:
    failure_threshold: 5
    timeout_seconds: 10.0
    recovery_timeout_seconds: 120.0
  news_api:
    failure_threshold: 5
    timeout_seconds: 10.0
    recovery_timeout_seconds: 120.0
ml_config_tuner:
  enabled: true
  min_samples: 20
  min_confidence: 0.6
  auto_apply: true
  auto_apply_min_confidence: 0.85
session_protection:
  enabled: true
  lock_tiers:
  - threshold_usd: 300
    retain_pct: 85.0
    label: DAILY GOAL
  - threshold_usd: 500
    retain_pct: 90.0
    label: STRONG DAY
  - threshold_usd: 1000
    retain_pct: 92.0
    label: HOME RUN
  - threshold_usd: 3000
    retain_pct: 95.0
    label: JACKPOT
  hwm_giveback_enabled: true
  hwm_max_giveback_pct: 25.0
  hwm_min_peak_usd: 400.0
  tighten_enabled: true
  tighten_target_usd: 1500.0
  tighten_factor: 0.5
  freeroll_enabled: true
  freeroll_min_quality_score: 90.0
  freeroll_min_house_money_usd: 50.0
  spam_throttle_minutes: 5.0
