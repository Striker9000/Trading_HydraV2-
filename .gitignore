.venv/

# Logs and state (created at runtime)
logs/*.jsonl
state/*.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Secrets (never commit these!)
*.key
*.pem
